{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "projectseniorservice",
  "main": "src/index.js",
  "compatibility_date": "2026-06-18",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "triggers": {
    "crons": [
      "*/5 * * * *"
    ]
  },
  "vars": {
    "PROJECT_NAME": "projectseniorservice",
    "ASSISTANT_NAME": "Соня",
    "PRIMARY_UI_LANGUAGE": "uk",
    "SECONDARY_UI_LANGUAGE": "en",
    "UNDERSTOOD_INPUT_LANGUAGES": "uk,ru,en,surzhyk",
    "DEFAULT_TIMEZONE": "Europe/Kyiv",
    "OPENAI_MODEL": "gpt-4.1-mini",
    "GEMINI_MODEL": "gemini-2.5-flash",
    "QUIET_HOURS_START": "23:00",
    "QUIET_HOURS_END": "08:00",
    "MAIL_DOMAIN": "web-library.net",
    "DEFAULT_WEATHER_LOCATION": "Obukhiv, Ukraine",
    "FILE_STORAGE_MODE": "metadata_only",
    "VOICE_INPUT_ENABLED": "false",
    "SONYA_VERSION": "sonya-v15-google-account-picker-avatar"
  },
  "kv_namespaces": [
    {
      "binding": "SONYA_KV",
      "id": "1871b5152bde4980be4c656ac27a446e"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "projectseniorservice",
      "database_id": "41ef1a3a-903c-494f-aff4-af2ff9d2ceef"
    }
  ]
}
